# --- media (never commit source or output video) ---
*.mp4
*.mkv
*.mov
*.avi
*.webm
*.m4v
*.gif
*.flv
*.wmv

# --- extracted frames / images ---
*.png
*.jpg
*.jpeg
*.bmp
*.tiff

# --- output / scratch dirs ---
/output/
/out/
/work/
/frames/
/segments/

# --- bundled third-party binaries (provision with setup.ps1) ---
# ffmpeg.exe / ffprobe.exe exceed GitHub's 100 MB file limit and are
# redistributables, so they are fetched locally rather than committed.
/bin/

# --- python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# --- os / editor ---
Thumbs.db
Desktop.ini
.DS_Store
.vscode/
.idea/
